    "grok-qwen": "./bins/grok-qwen.js",
    "grok-opencode-go": "./bins/grok-opencode-go.js"
  },
  "scripts": {
    "start": "node tui.js",
    "install-all": "node tui.js all"
  },
  "engines": {
    "node": ">=18"
  },
